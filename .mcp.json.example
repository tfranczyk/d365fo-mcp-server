/**
 * Example .mcp.json configuration for Visual Studio 2022
 * Place this file in your solution root directory or in %USERPROFILE%\.mcp.json
 */
{
  "servers": {
    "xpp-completion": {
      "url": "https://your-app-name.azurewebsites.net/mcp/",
      "description": "X++ Code Completion Server for D365 F&O"
    },
    "context": {
      "workspacePath": "K:\\AOSService\\PackagesLocalDirectory\\YourModelName",
      "packagePath": "K:\\AOSService\\PackagesLocalDirectory"
    }
  }
}
